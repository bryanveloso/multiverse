{
  "extends": "@multiverse/config/typescript/base",
  "compilerOptions": {
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "types": ["bun"],
    "paths": {
      "@/*": ["./src/*"],
      "@multiverse/ui/*": ["../../packages/ui/*"],
      "@multiverse/shared/*": ["../../packages/shared/*"]
    }
  }
}
