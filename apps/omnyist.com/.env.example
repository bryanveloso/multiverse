# Questlog API base used by build-time (.astro) data fetching.
QUESTLOG_API_URL=http://localhost:7176/api

# Questlog API base used by client-side React islands (must be PUBLIC_-prefixed
# so Astro exposes it to the browser). Defaults to the public tunnel if unset.
PUBLIC_QUESTLOG_API_URL=https://questlog.omnyist.com/api
