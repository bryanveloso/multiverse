---
import type { WorkDetail } from '@multiverse/data/questlog'

interface Props {
  work: WorkDetail
}

const { work } = Astro.props

const editionTypeLabels: Record<string, string> = {
  original: 'Original',
  remaster: 'Remaster',
  remake: 'Remake',
  port: 'Port',
  definitive: 'Definitive Edition',
  collection: 'Collection',
}

// Sort editions: original first, then by release date
const sortedEditions = [...work.editions].sort((a, b) => {
  if (a.edition_type === 'original') return -1
  if (b.edition_type === 'original') return 1
  if (!a.release_date) return 1
  if (!b.release_date) return -1
  return a.release_date.localeCompare(b.release_date)
})
---

<article class="py-8">
  <header class="mb-8">
    <a href="/gaming/" class="text-sm text-gray-500 hover:text-gray-700 mb-4 inline-block">
      ← Back to Gaming
    </a>
    <h1 class="text-4xl font-bold mb-2">{work.name}</h1>
    <div class="flex items-center gap-4 text-gray-600">
      {work.franchise && (
        <span>{work.franchise.name}</span>
      )}
      {work.original_release_year && (
        <span>Originally {work.original_release_year}</span>
      )}
    </div>
  </header>

  {sortedEditions.length > 0 && (
    <section>
      <h2 class="text-2xl font-semibold mb-4">Editions</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {sortedEditions.map((edition) => (
          <div class="rounded-lg bg-black-100 overflow-hidden">
            {edition.cover_url && (
              <img
                src={edition.cover_url}
                alt={`${edition.name} cover`}
                class="w-full aspect-[3/4] object-cover"
              />
            )}
            <div class="p-4">
              <h3 class="font-semibold mb-1">{edition.name}</h3>
              <div class="flex flex-wrap gap-2 text-xs text-gray-500 mb-2">
                <span class="px-2 py-0.5 bg-black-200 rounded">
                  {editionTypeLabels[edition.edition_type] || edition.edition_type}
                </span>
                {edition.release_date && (
                  <span>{new Date(edition.release_date).getFullYear()}</span>
                )}
              </div>
              {edition.summary && (
                <p class="text-sm text-gray-600 line-clamp-3">{edition.summary}</p>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {sortedEditions.length === 0 && (
    <p class="text-gray-500">No editions recorded yet.</p>
  )}
</article>
