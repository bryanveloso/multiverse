{
  "name": "multiverse",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "build:avalonstar.com": "turbo run build --filter=avalonstar.com",
    "build:bryanvelo.so": "turbo run build --filter=bryanvelo.so",
    "build:omnyist.com": "turbo run build --filter=omnyist.com",
    "dev:avalonstar.com": "turbo run dev --filter=avalonstar.com",
    "dev:bryanvelo.so": "turbo run dev --filter=bryanvelo.so",
    "dev:omnyist.com": "turbo run dev --filter=omnyist.com",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.5",
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-satteri": "0.3.2",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/react": "^6.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.3",
    "dotenv": "^17.4.2",
    "sharp": "^0.35.2"
  }
}
